{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CCR-MPC Final Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_title",
    "created_utc",
    "git_commit",
    "completion_message",
    "theory",
    "code",
    "experiments",
    "plots",
    "paper",
    "reports",
    "claim_ledger",
    "known_limitations"
  ],
  "properties": {
    "paper_title": {
      "type": "string",
      "minLength": 1
    },
    "created_utc": {
      "type": "string",
      "format": "date-time"
    },
    "git_commit": {
      "type": "string",
      "minLength": 7
    },
    "completion_message": {
      "type": "string"
    },
    "theory": {
      "$ref": "#/definitions/artifact_group"
    },
    "code": {
      "$ref": "#/definitions/artifact_group"
    },
    "experiments": {
      "$ref": "#/definitions/artifact_group"
    },
    "plots": {
      "$ref": "#/definitions/artifact_group"
    },
    "paper": {
      "$ref": "#/definitions/artifact_group"
    },
    "reports": {
      "$ref": "#/definitions/artifact_group"
    },
    "claim_ledger": {
      "type": "string",
      "minLength": 1
    },
    "known_limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "artifact_group": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "sha256",
          "description"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-fA-F0-9]{64}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
